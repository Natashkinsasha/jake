{
  "name": "jake",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:migrate": "pnpm --filter @jake/api db:migrate",
    "db:seed": "pnpm --filter @jake/api db:seed"
  },
  "devDependencies": {
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.1",
    "turbo": "^2.3.0",
    "typescript": "^5.5.3"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.19.12"
    }
  },
  "volta": {
    "node": "22.22.0"
  }
}
