{
  "name": "jake",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "type-check": "turbo type-check",
    "db:migrate": "pnpm --filter @jake/api db:migrate",
    "db:seed": "pnpm --filter @jake/api db:seed",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.5.3"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "glob": ">=10.5.0",
      "express-rate-limit": ">=8.2.2",
      "tar": ">=7.5.10",
      "serialize-javascript": ">=7.0.3",
      "lodash": ">=4.17.23",
      "webpack": ">=5.104.1",
      "@tootallnate/once": ">=3.0.1",
      "tmp": ">=0.2.4"
    }
  },
  "volta": {
    "node": "22.22.0"
  }
}
